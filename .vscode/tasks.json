{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Start PHP Server",
            "type": "shell",
            "command": "php",
            "args": [
                "-S",
                "127.0.0.1:8080",
                "index.php"
            ],
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": true,
                "panel": "shared"
            },
            "isBackground": true,
            "problemMatcher": {
                "pattern": {
                    "regexp": "^.*Listening on http://127\\.0\\.0\\.1:8080.*$",
                    "file": 1
                },
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": "^.*Listening on.*$",
                    "endsPattern": "^.*$"
                }
            },
            "runOptions": {
                "runOn": "default"
            }
        }
    ]
}
